switch (object_index)
{
	case oButton_approve:		sprite_index = sApprove2; break;
    case oButton_reject:		sprite_index = sReject2; break;
    case oButton_nextday:		sprite_index = sNext2; break;
    case oButton_restart_room:	sprite_index = sRestart2; break;
    case oButton_mainmenu:		sprite_index = sMenu2; break;
	case oButton_play:			sprite_index = sPlay2; break;
	case oButton_quit:			sprite_index = sQuit2; break;
}