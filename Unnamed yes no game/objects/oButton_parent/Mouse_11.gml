switch (object_index)
{
	case oButton_approve:		sprite_index = sApprove1; break;
    case oButton_reject:		sprite_index = sReject1; break;
    case oButton_nextday:		sprite_index = sNext1; break;
    case oButton_restart_room:	sprite_index = sRestart1; break;
    case oButton_mainmenu:		sprite_index = sMenu1; break;
	case oButton_play:			sprite_index = sPlay1; break;
	case oButton_quit:			sprite_index = sQuit1; break;
}